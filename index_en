  <script>
    const months=['Jan','Feb','Mar','Apr','May','Jun','Jul','Aug','Sep','Oct','Nov','Dec'];
    const days=['Sunday','Monday','Tuesday','Wednesday','Thursday','Friday','Saturday'];
    const now=new Date();
    document.getElementById('gunluk-date-label').textContent=days[now.getDay()]+' '+now.getDate()+' '+months[now.getMonth()];
    const KEY='gunluk_'+now.toISOString().slice(0,10);
    const textEl=document.getElementById('gunluk-text');
    const inputEl=document.getElementById('gunluk-input');
    const btnEl=document.getElementById('gunluk-btn');
    const charEl=document.getElementById('gunluk-char');
    const saved=localStorage.getItem(KEY);
    if(saved)textEl.textContent=saved;
    let editing=false;
    function toggleGunluk(){
      editing=!editing;
      if(editing){
        inputEl.value=(textEl.textContent==="✦ What's today?")?'':textEl.textContent;
        textEl.style.display='none';inputEl.style.display='block';charEl.style.display='inline';
        charEl.textContent=50-inputEl.value.length;btnEl.textContent='Save';inputEl.focus();
      }else{
        const val=inputEl.value.trim();
        textEl.textContent=val||"✦ What's today?";
        if(val)localStorage.setItem(KEY,val);
        textEl.style.display='block';inputEl.style.display='none';charEl.style.display='none';btnEl.textContent='Edit';
      }
    }
    inputEl.addEventListener('input',()=>{charEl.textContent=50-inputEl.value.length;});
    inputEl.addEventListener('keydown',(e)=>{if(e.key==='Enter')toggleGunluk();});
    textEl.addEventListener('click',()=>{if(!editing)toggleGunluk();});
  </script>
